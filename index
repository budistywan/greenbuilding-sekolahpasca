    [ {n:"R. Dosen A",u0:0,u1:.33,v0:0,v1:.65}, {n:"R. Dosen B",u0:.33,u1:.66,v0:0,v1:.65},
      {n:"R. Dosen C",u0:.66,u1:1,v0:0,v1:.65}, {n:"Koridor",u0:0,u1:1,v0:.65,v1:.78},
      {n:"R. Penelitian",u0:0,u1:.60,v0:.78,v1:1}, {n:"Toilet",u0:.60,u1:1,v0:.78,v1:1} ],
    [ {n:"R. Dekan",u0:0,u1:.40,v0:0,v1:.55}, {n:"R. Wakil Dekan",u0:.40,u1:1,v0:0,v1:.55},
      {n:"R. Rapat Besar",u0:0,u1:.65,v0:.55,v1:1}, {n:"Sekretariat",u0:.65,u1:1,v0:.55,v1:.80},
      {n:"Toilet",u0:.65,u1:1,v0:.80,v1:1} ],
  ];

  const ROOM_INDICES = {
    A: [[.35,.42,.80,.78,.60,.55],[.48,.52,.85,.72,.79,.68],[.55,.61,.58,.82,.77,.70],[.72,.68,.75,.84,.71,.80],[.82,.78,.88,.76,.83]],
    B: [[.30,.38,.75,.72,.55,.50],[.42,.46,.80,.68,.74,.62],[.50,.58,.54,.78,.73,.65],[.65,.62,.70,.80,.68,.76],[.76,.72,.84,.71,.79]],
  };

  function indexToColor(v) {
    if (v < .4)  return new Cesium.Color(.72+.08*(v/.4), .12+.08*(v/.4), .12+.08*(v/.4), .88);
    if (v < .65) { const t=(v-.4)/.25; return new Cesium.Color(.78+.05*t,.55+.05*t,.10+.06*t,.85); }
    const t=(v-.65)/.35; return new Cesium.Color(.08+.05*t,.45+.10*t,.36+.12*t,.82);
  }
  function indexToLabel(v) { return v<.4?"Alert":v<.65?"Review":"OK"; }

  /* ── VIEWER ── */
  const viewer = new Cesium.Viewer("cesiumContainer", {
    terrain: Cesium.Terrain.fromWorldTerrain(),
    animation:false, timeline:false, baseLayerPicker:false,
    geocoder:false, homeButton:false, sceneModePicker:false,
    navigationHelpButton:false, fullscreenButton:false,
    infoBox:true, selectionIndicator:true,
  });
  viewer.scene.globe.depthTestAgainstTerrain = true;
  viewer.scene.globe.enableLighting = true;
  viewer.shadows = true;

  /* ── OSM ── */
  const osm = await Cesium.Cesium3DTileset.fromIonAssetId(96188);
  viewer.scene.primitives.add(osm);
  const hiddenIds = BUILDINGS.map(b=>b.elementId);
  osm.style = new Cesium.Cesium3DTileStyle({
    show: `!(${hiddenIds.map(id=>`\${elementId} === ${id}`).join(" || ")})`,
  });

  /* ── UTILS ── */
  function centroid(fp) {
    let lon=0,lat=0; const n=fp.length/2;
    for(let i=0;i<fp.length;i+=2){lon+=fp[i];lat+=fp[i+1];}
    return {lon:lon/n,lat:lat/n};
  }
  async function sampleGround(lon,lat) {
    try {
      const r = await Promise.race([
        Cesium.sampleTerrainMostDetailed(viewer.scene.globe.terrainProvider,[Cesium.Cartographic.fromDegrees(lon,lat)]),
        new Promise((_,rej)=>setTimeout(()=>rej(new Error("timeout")),6000)),
      ]);
      return r[0]?.height??0;
    } catch { return 5; }
  }
  function bilinear(fp,u,v) {
    const p=[{lon:fp[0],lat:fp[1]},{lon:fp[2],lat:fp[3]},{lon:fp[4],lat:fp[5]},{lon:fp[6],lat:fp[7]}];
    const lerp=(a,b,t)=>({lon:a.lon+(b.lon-a.lon)*t,lat:a.lat+(b.lat-a.lat)*t});
    return lerp(lerp(p[0],p[3],u),lerp(p[1],p[2],u),v);
  }
  function subFootprint(fp,u0,u1,v0,v1) {
    const c00=bilinear(fp,u0,v0),c10=bilinear(fp,u1,v0),c11=bilinear(fp,u1,v1),c01=bilinear(fp,u0,v1);
    return [c00.lon,c00.lat,c01.lon,c01.lat,c11.lon,c11.lat,c10.lon,c10.lat];
  }

  /* ── BUILD ROOMS ── */
  const allRooms = [];
  function buildRooms(b, groundM) {
    const idxMap = ROOM_INDICES[b.key];
    for (let fl=0; fl<b.levels; fl++) {
      const bot = groundM + fl*b.floorHeight;
      const top = groundM + (fl+1)*b.floorHeight;
      FLOOR_LAYOUTS[fl].forEach((rm,ri) => {
        const idx = idxMap[fl][ri]??0.5;
        const ent = viewer.entities.add({
          name: `${b.name} · L${fl+1} · ${rm.n}`,
          polygon: {
            hierarchy: Cesium.Cartesian3.fromDegreesArray(subFootprint(b.footprint,rm.u0,rm.u1,rm.v0,rm.v1)),
            height:bot, extrudedHeight:top,
            material: indexToColor(idx),
            outline:true, outlineColor:Cesium.Color.BLACK.withAlpha(.4),
            closeTop:true, closeBottom:true,
          },
          properties: { __kind:"room", gedung:b.key, lantai:fl+1, ruang:rm.n, index:idx, status:indexToLabel(idx), bottomM:bot, topM:top },
        });
        allRooms.push(ent);
      });
    }
    // Atap
    viewer.entities.add({
      polygon: {
        hierarchy: Cesium.Cartesian3.fromDegreesArray(b.footprint),
        height: groundM+b.levels*b.floorHeight,
        extrudedHeight: groundM+b.levels*b.floorHeight+b.roofExtra,
        material: Cesium.Color.fromCssColorString("#3a3a3a").withAlpha(.80),
        outline:true, outlineColor:Cesium.Color.BLACK.withAlpha(.4),
        closeTop:true, closeBottom:true,
      },
    });
  }

  const centroids = BUILDINGS.map(b=>centroid(b.footprint));
  const grounds   = await Promise.all(centroids.map(c=>sampleGround(c.lon,c.lat)));
  BUILDINGS.forEach((b,i)=>buildRooms(b,grounds[i]));

  const midLon = (centroids[0].lon+centroids[1].lon)/2;
  const midLat = (centroids[0].lat+centroids[1].lat)/2;
  const avgGnd = (grounds[0]+grounds[1])/2;
  const hMax   = Math.max(...BUILDINGS.map(b=>b.levels*b.floorHeight+b.roofExtra));
  const camCtr = Cesium.Cartesian3.fromDegrees(midLon, midLat, avgGnd+hMax*.6);

  /* ── CAMERA ── */
  let _tick=null, _orbitPaused=false, _orbitAngle=Cesium.Math.toRadians(35);

  function stopOrbit(rel=true) {
    if(_tick){viewer.clock.onTick.removeEventListener(_tick);_tick=null;}
    if(rel) viewer.camera.lookAtTransform(Cesium.Matrix4.IDENTITY);
    _orbitPaused=false;
  }
  function startIdleOrbit({speed=.0008,range=120,pitchDeg=-35}={}) {
    stopOrbit();
    _orbitAngle=viewer.camera.heading;
    _tick=()=>{
      if(_orbitPaused)return;
      _orbitAngle+=speed;
      viewer.camera.lookAt(camCtr,new Cesium.HeadingPitchRange(_orbitAngle,Cesium.Math.toRadians(pitchDeg),range));
    };
    viewer.clock.onTick.addEventListener(_tick);
  }
  async function introReveal() {
    stopOrbit();
    await viewer.camera.flyTo({
      destination:Cesium.Cartesian3.fromDegrees(midLon,midLat,hMax*8),
      orientation:{heading:Cesium.Math.toRadians(20),pitch:Cesium.Math.toRadians(-25)},
      duration:2.0,easingFunction:Cesium.EasingFunction.QUADRATIC_IN_OUT,
    });
    await viewer.camera.flyTo({
      destination:Cesium.Cartesian3.fromDegrees(midLon,midLat,hMax*3.2),
      orientation:{heading:Cesium.Math.toRadians(35),pitch:Cesium.Math.toRadians(-38)},
      duration:1.8,easingFunction:Cesium.EasingFunction.CUBIC_IN_OUT,
    });
    startIdleOrbit();
  }

  /* ── UI BUTTONS ── */
  document.getElementById("btnOverview").onclick=()=>{
    stopOrbit();
    viewer.camera.flyTo({
      destination:Cesium.Cartesian3.fromDegrees(midLon,midLat,hMax*3.2),
      orientation:{heading:Cesium.Math.toRadians(35),pitch:Cesium.Math.toRadians(-38)},
      duration:1.2,complete:()=>startIdleOrbit(),
    });
  };
  document.getElementById("btnCinematic").onclick=()=>introReveal();
  document.getElementById("btnOrbit").onclick=()=>startIdleOrbit();

  /* ── INTERACTION ── */
  let _sel=null,_selSnap=null,_hov=null,_hovSnap=null;
  function snap(e){return{material:e.polygon.material,outlineColor:e.polygon.outlineColor};}
  function restore(e,s){if(!e||!s)return;e.polygon.material=s.material;e.polygon.outlineColor=s.outlineColor;}
  function isRoom(e){return e?.properties?.__kind?.getValue?.() === "room";}

  const handler=new Cesium.ScreenSpaceEventHandler(viewer.scene.canvas);
  handler.setInputAction(mv=>{
    const picks=viewer.scene.drillPick(mv.endPosition);
    let hit=null;
    for(const p of picks){const e=p.id||(p.primitive?.id);if(e&&isRoom(e)){hit=e;break;}}
    if(_hov&&_hovSnap&&_hov!==_sel)restore(_hov,_hovSnap);
    _hov=null;_hovSnap=null;
    viewer.container.style.cursor=hit?"pointer":"default";
    if(!hit||hit===_sel)return;
    _hov=hit;_hovSnap=snap(hit);
    hit.polygon.material=Cesium.Color.WHITE.withAlpha(.88);
    hit.polygon.outlineColor=Cesium.Color.YELLOW.withAlpha(.9);
    _orbitPaused=true; setTimeout(()=>{_orbitPaused=false;},2000);
  },Cesium.ScreenSpaceEventType.MOUSE_MOVE);

  handler.setInputAction(click=>{
    if(_hov&&_hovSnap&&_hov!==_sel)restore(_hov,_hovSnap);
    _hov=null;_hovSnap=null;
    if(_sel&&_selSnap)restore(_sel,_selSnap);
    _sel=null;_selSnap=null;
    const picks=viewer.scene.drillPick(click.position);
    let hit=null;
    for(const p of picks){const e=p.id||(p.primitive?.id);if(e&&isRoom(e)){hit=e;break;}}
    if(!hit){viewer.selectedEntity=undefined;return;}
    _sel=hit;_selSnap=snap(hit);
    hit.polygon.material=Cesium.Color.YELLOW.withAlpha(.92);
    hit.polygon.outlineColor=Cesium.Color.WHITE.withAlpha(.95);
    const p=hit.properties;
    const get=k=>p[k]?.getValue?.()??p[k];
    const idx=get("index"),st=get("status");
    const sc={OK:"#1a7a62",Review:"#c8922a",Alert:"#b83232"}[st]||"#888";
    const bw=Math.round(idx*100);
    viewer.selectedEntity=new Cesium.Entity({
      name:hit.name,
      description:`<div style="font-family:system-ui,sans-serif;font-size:13px;padding:4px">
        <table style="width:100%;border-collapse:collapse;margin-bottom:10px">
          <tr><td style="color:#666;padding:4px 0;width:90px">Gedung</td><td><b>Gedung ${get("gedung")}</b></td></tr>
          <tr><td style="color:#666;padding:4px 0">Lantai</td><td>${get("lantai")}</td></tr>
          <tr><td style="color:#666;padding:4px 0">Ruang</td><td><b>${get("ruang")}</b></td></tr>
          <tr><td style="color:#666;padding:4px 0">Status</td><td><span style="background:${sc};color:#fff;padding:1px 9px;border-radius:10px;font-size:11px">${st}</span></td></tr>
          <tr><td style="color:#666;padding:4px 0">Elevasi</td><td>${Number(get("bottomM")).toFixed(1)}–${Number(get("topM")).toFixed(1)} m</td></tr>
        </table>
        <div style="font-size:11px;color:#666;margin-bottom:4px">Indeks komposit</div>
        <div style="background:#eee;border-radius:4px;height:8px;overflow:hidden;margin-bottom:4px">
          <div style="width:${bw}%;height:100%;background:${sc};border-radius:4px"></div>
        </div>
        <div style="font-size:12px;font-weight:500;color:${sc}">${idx.toFixed(2)} / 1.00</div>
        <div style="margin-top:8px;font-size:10px;color:#aaa">EUI · PMV · Occupancy · WAC</div>
      </div>`,
    });
    stopOrbit(false);
    const hierarchy=hit.polygon.hierarchy.getValue(Cesium.JulianDate.now());
    const pos=hierarchy.positions;
    let cx=0,cy=0,cz=0;pos.forEach(q=>{cx+=q.x;cy+=q.y;cz+=q.z;});
    const n=pos.length;
    const rc=new Cesium.Cartesian3(cx/n,cy/n,cz/n);
    const cart=Cesium.Cartographic.fromCartesian(rc);
    viewer.camera.flyTo({
      destination:Cesium.Cartesian3.fromDegrees(Cesium.Math.toDegrees(cart.longitude),Cesium.Math.toDegrees(cart.latitude)-.00012,get("topM")+40),
      orientation:{heading:Cesium.Math.toRadians(30),pitch:Cesium.Math.toRadians(-35)},
      duration:.9,easingFunction:Cesium.EasingFunction.QUADRATIC_IN_OUT,
      complete:()=>viewer.camera.lookAtTransform(Cesium.Matrix4.IDENTITY),
    });
  },Cesium.ScreenSpaceEventType.LEFT_CLICK);

  handler.setInputAction(async()=>{
    if(_hov&&_hovSnap&&_hov!==_sel)restore(_hov,_hovSnap);
    if(_sel&&_selSnap)restore(_sel,_selSnap);
    _hov=_hovSnap=_sel=_selSnap=null;
    viewer.selectedEntity=undefined;
    viewer.container.style.cursor="default";
    await viewer.camera.flyTo({
      destination:Cesium.Cartesian3.fromDegrees(midLon,midLat,hMax*3.2),
      orientation:{heading:Cesium.Math.toRadians(35),pitch:Cesium.Math.toRadians(-38)},
      duration:1.2,easingFunction:Cesium.EasingFunction.QUADRATIC_IN_OUT,
      complete:()=>{viewer.camera.lookAtTransform(Cesium.Matrix4.IDENTITY);startIdleOrbit();}
    });
  },Cesium.ScreenSpaceEventType.RIGHT_CLICK);

  await introReveal();
})();
</script>

