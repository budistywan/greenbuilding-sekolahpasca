<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Green Building Intelligence · SPs UNDIP</title>

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cesium.com/downloads/cesiumjs/releases/1.114/Build/Cesium/Cesium.js"></script>
<link href="https://cesium.com/downloads/cesiumjs/releases/1.114/Build/Cesium/Widgets/widgets.css" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

<style>
:root {
  --ink:      #111827;
  --ink2:     #1e2738;
  --surface:  #f4f1ec;
  --white:    #ffffff;
  --gold:     #c8922a;
  --gold-lt:  #fdf3e0;
  --gold-dk:  #7a5510;
  --teal:     #1a7a62;
  --teal-lt:  #e0f4ef;
  --teal-dk:  #0d4d3c;
  --blue:     #1e5fa8;
  --blue-lt:  #e8f0fb;
  --blue-dk:  #0d3566;
  --red:      #b83232;
  --red-lt:   #fceaea;
  --red-dk:   #6e1a1a;
  --gray:     #888580;
  --gray-lt:  #f0ede8;
  --border:   rgba(17,24,39,0.10);
  --border2:  rgba(17,24,39,0.20);
  --font-d:   'DM Serif Display', Georgia, serif;
  --font-b:   'DM Sans', system-ui, sans-serif;
  --font-m:   'DM Mono', monospace;
  --r:        10px;
  --r-lg:     16px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-b); background: var(--surface); color: var(--ink); font-size: 14px; line-height: 1.6; }

/* ── CESIUM SECTION ── */
#cesium-section {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 600px;
  overflow: hidden;
}
#cesiumContainer {
  width: 100%;
  height: 100%;
}
/* Cesium widget overrides */
.cesium-widget-credits { display: none !important; }

/* ── HERO OVERLAY ── */
#hero-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 10;
}

/* Top-left: identity */
#hero-id {
  position: absolute;
  top: 24px; left: 24px;
  pointer-events: auto;
}
#hero-id .eyebrow {
  font-size: 9px; font-weight: 500;
  letter-spacing: .14em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 6px;
}
#hero-id h1 {
  font-family: var(--font-d);
  font-size: clamp(22px, 3vw, 32px);
  color: #f0ede8;
  line-height: 1.15;
  text-shadow: 0 2px 12px rgba(0,0,0,0.5);
}
#hero-id h1 em { font-style: italic; color: var(--gold); }
#hero-id .sub {
  font-size: 11px; color: rgba(240,237,232,0.5);
  font-weight: 300; margin-top: 5px;
}

/* Top-right: camera controls */
#cam-controls {
  position: absolute;
  top: 24px; right: 24px;
  display: flex; flex-direction: column; gap: 6px;
  pointer-events: auto;
}
.cam-btn {
  padding: 7px 16px; font-size: 11px; font-weight: 500;
  font-family: var(--font-b); letter-spacing: .04em;
  background: rgba(10,14,26,0.78);
  color: #e8e6e1;
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 7px; cursor: pointer;
  backdrop-filter: blur(8px);
  transition: background .15s;
}
.cam-btn:hover { background: rgba(30,40,60,0.92); }

/* Bottom-right: legend */
#legend {
  position: absolute;
  bottom: 80px; right: 24px;
  background: rgba(10,14,26,0.85);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--r);
  padding: 12px 14px;
  backdrop-filter: blur(8px);
  pointer-events: auto;
}
#legend .leg-title {
  font-size: 8px; letter-spacing: .12em;
  text-transform: uppercase; color: rgba(232,230,225,0.4);
  margin-bottom: 8px; font-weight: 500;
}
.leg-row { display: flex; align-items: center; gap: 8px; font-size: 11px; color: #e8e6e1; margin-bottom: 5px; }
.leg-row:last-child { margin-bottom: 0; }
.leg-swatch { width: 24px; height: 8px; border-radius: 2px; flex-shrink: 0; }

/* Bottom-center: scroll cue */
#scroll-cue {
  position: absolute;
  bottom: 28px; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center;
  gap: 6px; pointer-events: none;
}
#scroll-cue .sc-label {
  font-size: 9px; letter-spacing: .12em; text-transform: uppercase;
  color: rgba(240,237,232,0.4); font-weight: 500;
}
#scroll-cue .sc-arrow {
  width: 1px; height: 32px;
  background: linear-gradient(to bottom, rgba(200,146,42,0.6), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}
@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
  50%       { opacity: 1.0; transform: scaleY(1.0); }
}

/* ── TRANSITION STRIP ── */
.strip {
  background: var(--ink);
  padding: 40px 28px 44px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 24px;
  align-items: center;
}
.strip-text .eyebrow {
  font-size: 9px; font-weight: 500; letter-spacing: .12em;
  text-transform: uppercase; color: var(--gold); margin-bottom: 8px;
}
.strip-text p {
  font-size: 15px; color: rgba(240,237,232,0.7);
  font-weight: 300; max-width: 520px; line-height: 1.7;
}
.strip-text p strong { color: #f0ede8; font-weight: 500; }
.strip-kpis { display: flex; gap: 32px; }
.strip-kpi { text-align: center; }
.strip-kpi .val {
  font-family: var(--font-m); font-size: 26px; font-weight: 500;
  color: #f0ede8; line-height: 1;
}
.strip-kpi .val small { font-size: 12px; font-weight: 300; color: rgba(240,237,232,0.45); }
.strip-kpi .lbl { font-size: 9px; color: rgba(240,237,232,0.4); margin-top: 4px; letter-spacing: .06em; }
.strip-div { width: 1px; background: rgba(255,255,255,0.1); height: 48px; }

/* ── DASHBOARD SECTION ── */
#dashboard { background: var(--surface); padding: 0 0 48px; }

.dash-header {
  padding: 32px 28px 0;
  display: flex; align-items: baseline; gap: 12px;
  margin-bottom: 20px;
}
.dash-title { font-family: var(--font-d); font-size: 22px; color: var(--ink); }
.dash-rule { flex: 1; height: 1px; background: var(--border); }
.dash-tag {
  font-size: 10px; font-weight: 500; letter-spacing: .08em;
  text-transform: uppercase; color: var(--gray);
}

.dash-body { padding: 0 28px; display: flex; flex-direction: column; gap: 14px; }

/* Metric strip */
.metric-strip { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; }
.m-card {
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: var(--r);
  padding: 14px 16px;
  position: relative; overflow: hidden;
}
.m-card::before {
  content: ''; position: absolute;
  top: 0; left: 0; right: 0; height: 3px;
}
.m-card.energy::before { background: var(--gold); }
.m-card.thermal::before { background: var(--teal); }
.m-card.water::before { background: var(--blue); }
.m-card.occ::before { background: var(--gray); }
.m-lbl { font-size: 9px; color: var(--gray); letter-spacing: .07em; text-transform: uppercase; margin-bottom: 6px; }
.m-val { font-family: var(--font-m); font-size: 24px; font-weight: 500; color: var(--ink); line-height: 1; }
.m-val small { font-size: 11px; font-weight: 300; color: var(--gray); }
.m-delta { font-size: 11px; margin-top: 5px; }
.d-good { color: var(--teal); }
.d-warn { color: var(--gold); }
.d-bad  { color: var(--red);  }
.m-base { font-size: 10px; color: var(--gray); margin-top: 2px; }

/* Two / three col */
.two-col   { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.three-col { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 14px; }

/* Card */
.card {
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: var(--r-lg);
  padding: 18px 20px;
  animation: fadeUp .5s ease both;
}
@keyframes fadeUp {
  from { opacity:0; transform:translateY(12px); }
  to   { opacity:1; transform:translateY(0); }
}
.c-title {
  font-size: 10px; font-weight: 500; letter-spacing: .08em;
  text-transform: uppercase; color: var(--gray);
  margin-bottom: 14px;
  display: flex; align-items: center; justify-content: space-between;
}
.c-tag { font-size: 10px; font-weight: 400; color: var(--gray); opacity: .7; text-transform: none; letter-spacing: 0; }
.chart-wrap { position: relative; width: 100%; }

/* Score */
.score-row { display: flex; align-items: center; gap: 16px; margin-bottom: 14px; padding-bottom: 14px; border-bottom: 0.5px solid var(--border); }
.score-circle {
  width: 68px; height: 68px; border-radius: 50%;
  border: 2px solid var(--border2);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.score-num { font-family: var(--font-m); font-size: 20px; font-weight: 500; color: var(--ink); line-height: 1; }
.score-den { font-size: 10px; color: var(--gray); }
.score-info .rating { font-family: var(--font-d); font-size: 19px; color: var(--gold); }
.score-info .gap { font-size: 11px; color: var(--gray); }
.score-info .gap strong { color: var(--ink); font-weight: 500; }
.cat-list { display: flex; flex-direction: column; gap: 8px; }
.cat-row  { display: flex; align-items: center; gap: 8px; }
.cat-nm { font-size: 11px; font-weight: 500; color: var(--ink); width: 40px; flex-shrink: 0; }
.cat-bg { flex: 1; height: 6px; background: var(--gray-lt); border-radius: 3px; overflow: hidden; }
.cat-fill { height: 100%; border-radius: 3px; }
.cat-pt { font-family: var(--font-m); font-size: 10px; color: var(--gray); width: 34px; text-align: right; flex-shrink: 0; }
.gap-box {
  background: var(--gold-lt);
  border-left: 3px solid var(--gold);
  padding: 9px 12px; margin-top: 12px;
  font-size: 11px; color: var(--gold-dk);
}
.gap-box strong { font-weight: 500; }

/* Floor table */
.ft { width: 100%; border-collapse: collapse; font-size: 12px; }
.ft th {
  font-size: 9px; font-weight: 500; letter-spacing: .08em;
  text-transform: uppercase; color: var(--gray);
  padding: 5px 8px; text-align: left;
  border-bottom: 0.5px solid var(--border);
}
.ft td {
  padding: 6px 8px;
  border-bottom: 0.5px solid var(--border);
  font-family: var(--font-m);
}
.ft td:first-child { font-family: var(--font-b); font-weight: 500; }
.ft tr:last-child td { border-bottom: none; }
.ft tr:hover td { background: var(--surface); }
.pill { display: inline-block; padding: 1px 8px; border-radius: 10px; font-size: 9px; font-weight: 500; font-family: var(--font-b); }
.p-ok   { background: var(--teal-lt); color: var(--teal-dk); }
.p-warn { background: var(--gold-lt); color: var(--gold-dk); }
.p-alrt { background: var(--red-lt);  color: var(--red-dk);  }

/* Rec list */
.rec-list { list-style: none; display: flex; flex-direction: column; gap: 0; margin-top: 10px; }
.rec-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 0.5px solid var(--border); }
.rec-item:last-child { border-bottom: none; }
.rec-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
.rec-cat { font-size: 9px; font-weight: 500; padding: 2px 6px; border-radius: 4px; flex-shrink: 0; margin-top: 2px; }
.rec-text { font-size: 12px; color: var(--ink); line-height: 1.5; }
.rec-pt   { font-size: 10px; color: var(--gray); margin-top: 2px; }

.legend-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px; }
.legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--gray); }
.legend-sw { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
.legend-ln { width: 16px; height: 2px; flex-shrink: 0; }

/* Footer */
.footer {
  background: var(--ink); color: rgba(240,237,232,0.4);
  padding: 16px 28px; font-size: 10px; letter-spacing: .04em;
  display: flex; justify-content: space-between; align-items: center;
}
.footer strong { color: rgba(240,237,232,0.7); font-weight: 500; }
</style>
</head>
<body>

<!-- ══════════════════════════════════════════
     SECTION 1 — CESIUM HERO
══════════════════════════════════════════ -->
<section id="cesium-section">
  <div id="cesiumContainer"></div>

  <div id="hero-overlay">

    <!-- Identity -->
    <div id="hero-id">
      <div class="eyebrow">Green Building Intelligence · GBCI Greenship</div>
      <h1>Sekolah Pascasarjana<br><em>Universitas Diponegoro</em></h1>
      <div class="sub">Semarang · Kampus Pleburan · Digital Twin 3D</div>
    </div>

    <!-- Camera controls -->
    <div id="cam-controls">
      <button class="cam-btn" id="btnOverview">⟳ Overview</button>
      <button class="cam-btn" id="btnCinematic">▶ Cinematic</button>
      <button class="cam-btn" id="btnOrbit">◎ Orbit</button>
    </div>

    <!-- Legend -->
    <div id="legend">
      <div class="leg-title">Indeks Komposit per Ruang</div>
      <div class="leg-row"><span class="leg-swatch" style="background:#b81e1e"></span>0.0–0.4 · Alert</div>
      <div class="leg-row"><span class="leg-swatch" style="background:#c87020"></span>0.4–0.65 · Review</div>
      <div class="leg-row"><span class="leg-swatch" style="background:#0e6640"></span>0.65–1.0 · OK</div>
      <div style="margin-top:8px;padding-top:8px;border-top:1px solid rgba(255,255,255,0.08);font-size:9px;color:rgba(232,230,225,0.3)">
        Klik ruang → detail · Klik kanan → reset
      </div>
    </div>

    <!-- Scroll cue -->
    <div id="scroll-cue">
      <div class="sc-label">scroll</div>
      <div class="sc-arrow"></div>
    </div>

  </div>
</section>

<!-- ══════════════════════════════════════════
     SECTION 2 — TRANSITION STRIP
══════════════════════════════════════════ -->
<div class="strip">
  <div class="strip-text">
    <div class="eyebrow">Sistem monitoring terintegrasi</div>
    <p>
      Setiap ruang di Gedung A &amp; B diukur secara <strong>kontinu</strong> —
      energi, kenyamanan termal, dan tingkat hunian — lalu dirangkum menjadi
      <strong>indeks komposit</strong> yang terlihat langsung pada model 3D di atas.
      Dashboard di bawah menampilkan detail per kategori Greenship GBCI.
    </p>
  </div>
  <div class="strip-kpis">
    <div class="strip-kpi">
      <div class="val">187 <small>kWh/m²</small></div>
      <div class="lbl">EUI Aktual</div>
    </div>
    <div class="strip-div"></div>
    <div class="strip-kpi">
      <div class="val">+0.3 <small>PMV</small></div>
      <div class="lbl">Thermal Comfort</div>
    </div>
    <div class="strip-div"></div>
    <div class="strip-kpi">
      <div class="val">68 <small>%</small></div>
      <div class="lbl">Avg Occupancy</div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     SECTION 3 — DASHBOARD
══════════════════════════════════════════ -->
<section id="dashboard">

  <div class="dash-header">
    <span class="dash-title">Dashboard operasional</span>
    <div class="dash-rule"></div>
    <span class="dash-tag">Data simulasi · April 2026</span>
  </div>

  <div class="dash-body">

    <!-- Metric strip -->
    <div class="metric-strip">
      <div class="m-card energy">
        <div class="m-lbl">EUI Aktual</div>
        <div class="m-val">187 <small>kWh/m²/th</small></div>
        <div class="m-delta d-good">↓ −11% vs tahun lalu</div>
        <div class="m-base">Baseline SNI: 200 · Target Gold: ≤170</div>
      </div>
      <div class="m-card thermal">
        <div class="m-lbl">Thermal Comfort</div>
        <div class="m-val">+0.3 <small>PMV</small></div>
        <div class="m-delta d-good">Dalam rentang ±0.5 (IHC)</div>
        <div class="m-base">Avg 24.8°C · RH 58%</div>
      </div>
      <div class="m-card water">
        <div class="m-lbl">Konsumsi Air</div>
        <div class="m-val">8.4 <small>L/org/hari</small></div>
        <div class="m-delta d-warn">↑ +3% vs target WAC</div>
        <div class="m-base">Recycling 22% · target ≥30%</div>
      </div>
      <div class="m-card occ">
        <div class="m-lbl">Avg Occupancy</div>
        <div class="m-val">68 <small>%</small></div>
        <div class="m-delta d-bad">↓ −5% vs target utilisasi</div>
        <div class="m-base">Peak: 09.00–11.00 WIB</div>
      </div>
    </div>

    <!-- Charts row 1 -->
    <div class="two-col">
      <div class="card">
        <div class="c-title">Energi vs Occupancy — bulanan <span class="c-tag">Okt 2025–Apr 2026</span></div>
        <div class="chart-wrap" style="height:200px">
          <canvas id="cEnergy" role="img" aria-label="EUI dan occupancy bulanan">Data energi bulanan.</canvas>
        </div>
        <div class="legend-row">
          <span class="legend-item"><span class="legend-ln" style="background:#c8922a"></span>EUI kWh/m²</span>
          <span class="legend-item"><span class="legend-ln" style="background:#1e5fa8;border-top:2px dashed #1e5fa8"></span>Occupancy %</span>
          <span class="legend-item"><span class="legend-ln" style="background:#b83232"></span>Target 170</span>
        </div>
      </div>
      <div class="card">
        <div class="c-title">Thermal comfort per lantai — PMV <span class="c-tag">Rata-rata April</span></div>
        <div class="chart-wrap" style="height:200px">
          <canvas id="cThermal" role="img" aria-label="PMV per lantai">PMV per lantai.</canvas>
        </div>
        <div class="legend-row">
          <span class="legend-item"><span class="legend-sw" style="background:#1a7a62"></span>Gedung A</span>
          <span class="legend-item"><span class="legend-sw" style="background:#7f77dd"></span>Gedung B</span>
          <span class="legend-item"><span class="legend-ln" style="background:#b83232"></span>Batas ±0.5</span>
        </div>
      </div>
    </div>

    <!-- Charts row 2 -->
    <div class="three-col">
      <div class="card">
        <div class="c-title">Korelasi occupancy vs EUI <span class="c-tag">Titik merah = tidak efisien</span></div>
        <div class="chart-wrap" style="height:220px">
          <canvas id="cScatter" role="img" aria-label="Scatter occupancy vs EUI">Korelasi occupancy dan EUI.</canvas>
        </div>
        <div style="font-size:11px;color:var(--gray);margin-top:8px">Lantai di atas garis = boros relatif terhadap tingkat hunian</div>
      </div>

      <div class="card">
        <div class="c-title">Skor Greenship GBCI</div>
        <div class="score-row">
          <div class="score-circle">
            <div class="score-num">61</div>
            <div class="score-den">/ 100</div>
          </div>
          <div class="score-info">
            <div class="rating">Silver</div>
            <div class="gap">Butuh <strong>+13 poin</strong> untuk Gold</div>
          </div>
        </div>
        <div class="cat-list">
          <div class="cat-row"><span class="cat-nm">EEC</span><div class="cat-bg"><div class="cat-fill" style="width:62%;background:#c8922a"></div></div><span class="cat-pt">21/34</span></div>
          <div class="cat-row"><span class="cat-nm">IHC</span><div class="cat-bg"><div class="cat-fill" style="width:70%;background:#1a7a62"></div></div><span class="cat-pt">14/20</span></div>
          <div class="cat-row"><span class="cat-nm">WAC</span><div class="cat-bg"><div class="cat-fill" style="width:55%;background:#1e5fa8"></div></div><span class="cat-pt">11/20</span></div>
          <div class="cat-row"><span class="cat-nm">ASD</span><div class="cat-bg"><div class="cat-fill" style="width:80%;background:#7f77dd"></div></div><span class="cat-pt">8/10</span></div>
          <div class="cat-row"><span class="cat-nm">BEM</span><div class="cat-bg"><div class="cat-fill" style="width:44%;background:#888580"></div></div><span class="cat-pt">7/16</span></div>
        </div>
        <div class="gap-box">Gap ke Gold: <strong>13 poin</strong> — prioritas EEC &amp; BEM</div>
      </div>

      <div class="card">
        <div class="c-title">Detail per lantai</div>
        <table class="ft">
          <thead><tr><th>Lantai</th><th>EUI</th><th>PMV</th><th>Occ</th><th>—</th></tr></thead>
          <tbody>
            <tr><td>A-5</td><td>172</td><td>+0.2</td><td>82%</td><td><span class="pill p-ok">OK</span></td></tr>
            <tr><td>A-4</td><td>185</td><td>+0.4</td><td>74%</td><td><span class="pill p-ok">OK</span></td></tr>
            <tr><td>A-3</td><td>201</td><td>+0.6</td><td>55%</td><td><span class="pill p-warn">Review</span></td></tr>
